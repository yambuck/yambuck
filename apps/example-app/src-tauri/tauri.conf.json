{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Example App",
  "version": "0.3.0",
  "identifier": "com.yambuck.exampleapp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
        {
        "title": "Yambuck Example App",
        "width": 960,
        "height": 680,
        "minWidth": 760,
        "minHeight": 560,
        "decorations": false
        }
      ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
